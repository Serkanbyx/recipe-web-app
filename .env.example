# Spoonacular API key — used only in local development (Vite exposes VITE_* to the client).
# Get a free key at https://spoonacular.com/food-api
# In production the key is read from the SPOONACULAR_API_KEY Netlify environment variable
# by the serverless function, so it is NEVER shipped to the browser.
VITE_SPOONACULAR_API_KEY=your_api_key_here
